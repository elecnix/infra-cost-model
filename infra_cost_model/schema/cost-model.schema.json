{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/elecnix/infra-cost-model/blob/main/infra_cost_model/schema/cost-model.schema.json",
  "title": "Infrastructure Cost Model Representation",
  "description": "Single source of truth JSON Schema for YAML, TypeScript, and Python interfaces",

  "type": "object",
  "required": ["version", "nodes"],
  "anyOf": [
    { "required": ["workflow"] },
    { "required": ["workflows"] }
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "workflow": {
      "$ref": "#/definitions/workflow"
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/workflow" },
      "description": "Multiple independent workflows sharing the same infrastructure nodes. Each workflow has its own entry point, frequency, and optional parameters. Costs are aggregated across all workflows."
    },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/edge"
      }
    }
  },

  "definitions": {
    "workflow": {
      "type": "object",
      "required": ["name", "entry", "frequency"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Workflow identifier"
        },
        "entry": {
          "type": "string",
          "description": "Address of the entry node (receives external traffic)"
        },
        "frequency": {
          "type": "object",
          "required": ["unit", "value"],
          "properties": {
            "unit": {
              "type": "string",
              "enum": ["perSecond", "perMinute", "perHour", "perDay", "perWeek", "perMonth"],
              "description": "Time unit for entry frequency"
            },
            "value": {
              "type": "number",
              "minimum": 0,
              "description": "Invocation rate at the entry node"
            }
          }
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          },
          "description": "Symbolic variables for what-if analysis"
        }
      }
    },

    "nodeType": {
      "type": "string",
      "enum": ["compute", "storage", "routing", "external"],
      "description": "Node type determines valid usage metrics and edge permissions. External nodes are leaf nodes for third-party services (Stripe, Twilio)."
    },

    "node": {
      "type": "object",
      "required": ["nodeType", "resourceAddress"],
      "properties": {
        "nodeType": { "$ref": "#/definitions/nodeType" },
        "resourceAddress": {
          "type": "string",
          "description": "Infrastructure resource address (Terraform: aws_lambda_function.foo, Pulumi: aws:lambda:Function:foo, CDK: AWS::Lambda::Function/myApi/getItems)"
        },
        "provider": {
          "type": "string",
          "enum": ["aws", "azure", "gcp", "bedrock", "openai"],
          "description": "Cloud provider"
        },
        "service": {
          "type": "string",
          "description": "Service name (e.g., AWSLambda, DynamoDB)"
        },
        "region": {
          "type": "string",
          "description": "Cloud region (e.g., us-east-1)"
        },
        "usageMetrics": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/usageMetric"
          }
        },
        "pricingModel": {
          "type": "string",
          "enum": ["tiered", "flat", "token_based", "percentage"],
          "description": "Pricing model type. Percentage: fixed + percentage of transaction volume (e.g., Stripe: 2.9% + $0.30)."
        },
        "pricingRates": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          },
          "description": "Pricing rates per usage metric (used when price catalog unavailable)"
        },
        "flatOverride": {
          "type": "boolean",
          "default": false,
          "description": "When true, usageMetrics values are flat monthly totals (escape hatch, per DP#9). When false (default), values are per-invocation multipliers applied to the derived invocation count."
        }
      }
    },

    "usageMetric": {
      "type": "object",
      "required": ["unit"],
      "properties": {
        "unit": {
          "type": "string",
          "description": "Unit of measurement (e.g., requests, ms, MB, tokens)"
        },
        "description": {
          "type": "string"
        },
        "value": {
          "type": "number",
          "description": "Per-invocation multiplier. Multiplied by the derived invocation count to compute total consumption. When flatOverride is true on the containing node, this value is used directly as a flat monthly total instead."
        }
      }
    },

    "edge": {
      "type": "object",
      "required": ["from", "to", "rate"],
      "properties": {
        "from": {
          "type": "string",
          "description": "Source node resource address"
        },
        "to": {
          "type": "string",
          "description": "Target node resource address"
        },
        "rate": {
          "type": "number",
          "minimum": 0,
          "description": "Call rate: how many times parent invokes child per parent invocation"
        },
        "type": {
          "type": "string",
          "enum": ["read", "write", "invoke"],
          "default": "invoke",
          "description": "Type of call (read/write for database operations, invoke for compute)"
        },
        "dataSize": {
          "type": "object",
          "properties": {
            "unit": { "type": "string" },
            "average": { "type": "number", "description": "Average bytes per call" },
            "minimum": { "type": "number" },
            "maximum": { "type": "number" }
          }
        },
        "tokenFlow": {
          "type": "object",
          "properties": {
            "input": { "type": "number", "description": "Input/prompt tokens flowing through this edge per parent invocation" },
            "output": { "type": "number", "description": "Output/completion tokens flowing through this edge per parent invocation" }
          },
          "description": "Token flow for LLM-based edges. Input tokens flow downstream to LLM nodes; output tokens flow upstream to orchestration nodes."
        }
      }
    },

    "tieredPrice": {
      "type": "object",
      "required": ["start", "price"],
      "properties": {
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": ["number", "null"], "minimum": 0 },
        "price": { "type": "number", "minimum": 0 }
      }
    }
  }
}